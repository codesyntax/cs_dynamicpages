<div class="accordion shadow-sm mb-4"
     id="accordion-${context/UID}"
     tal:define="
       elements view/elements;
       macros context/@@macros/macros;
       can_edit context/can_edit;
     "
     tal:condition="elements"
>
  <div class="accordion-item border-0 border-bottom"
       tal:repeat="brain elements"
  >
    <div class="accordion-header h3 m-0">
      <button class="accordion-button collapsed fw-bold fs-5 bg-white text-dark"
              aria-controls="collapse-${brain/UID}"
              aria-expanded="false"
              type="button"
              data-bs-target="#collapse-${brain/UID}"
              data-bs-toggle="collapse"
      >
        ${brain/Title}
      </button>
    </div>
    <div class="accordion-collapse collapse"
         id="collapse-${brain/UID}"
         data-bs-parent="#accordion-${context/UID}"
    >
      <div class="accordion-body bg-light"
           tal:define="
             element brain/getObject;
           "
      >
        <metal:use_macro use-macro="macros/management_icons" />
        <tal:block replace="structure python:element.render(request)" />
      </div>
    </div>
    <metal:use_macro use-macro="macros/add_button">
      <metal:fill-slot fill-slot="position"
                       tal:define="
                         position python:repeat['brain'].index + 1;
                       "
      >${position}</metal:fill-slot>
      <metal:fill-slot fill-slot="container_uid"
                       tal:define="
                         container_uid context/UID;
                       "
      >${container_uid}</metal:fill-slot>
      <metal:fill-slot fill-slot="is_nested">True</metal:fill-slot>
    </metal:use_macro>
  </div>
</div>
