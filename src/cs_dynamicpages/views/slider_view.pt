<div class="carousel slide shadow-sm rounded overflow-hidden" id="DynamicPageSlider-${context/id}" tal:define="
       elements view/elements;
       fetchpriority_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'high' or 'auto') or 'auto';
       loading_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'eager' or 'lazy') or 'lazy';
     " tal:condition="elements">
  <div class="carousel-indicators">
    <tal:indicators repeat="element elements">
      <button class="active" aria-current="true" aria-label="Slide ${repeat/element/index}" type="button"
        data-bs-slide-to="${repeat/element/index}" data-bs-target="#DynamicPageSlider-${context/id}"
        i18n:attributes="aria-label"></button>
    </tal:indicators>
  </div>
  <div class="carousel-inner">
    <tal:slides repeat="brain elements">
      <div tal:define="
             element brain/getObject;
           " tal:attributes="
             class python: repeat['brain'].index == 0 and 'carousel-item active bg-dark' or 'carousel-item bg-dark';
           ">
        <tal:image tal:define="
                     image element/related_image_object;
                   " tal:condition="image">
          <div class="ratio ratio-21x9 w-100">
            <img class="object-fit-cover w-100 h-100 opacity-50" tal:define="
                   images image/@@images;
                 " tal:replace="structure python:images.srcset(fieldname='image',
                                                scale_in_src='huge',
                                                sizes='(min-width: 1400px) 1400px, 100vw',
                                                alt=image.Title() ,
                                                title=image.Title(),
                                                fetchpriority=fetchpriority_image_value,
                                                loading=loading_image_value,
                                                css_class='object-fit-cover w-100 h-100 opacity-50')" />
          </div>
        </tal:image>
        <div
          class="carousel-caption d-flex flex-column align-items-center justify-content-center h-100 top-0 bottom-0 p-4">
          <div class="p-4 p-md-5 rounded bg-dark bg-opacity-50">
            <h2 class="display-5 text-white fw-bold mb-3 shadow-sm">${element/Title}</h2>
            <p class="lead text-white mb-4 d-none d-md-block shadow-sm">${element/Description}</p>
            <a class="btn btn-primary btn-lg px-4 shadow-sm" href="${element/url}"
              tal:condition="element/url">${element/link_text}</a>
          </div>
        </div>
      </div>
    </tal:slides>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-slide="prev"
    data-bs-target="#DynamicPageSlider-${context/id}">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden" i18n:translate="">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-slide="next"
    data-bs-target="#DynamicPageSlider-${context/id}">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden" i18n:translate="">Next</span>
  </button>
</div>