<div class="carousel slide shadow-sm rounded overflow-hidden"
     id="DynamicPageSlider-${context/id}"
     tal:define="
       elements view/elements;
       fetchpriority_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'high' or 'auto') or 'auto';
       loading_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'eager' or 'lazy') or 'lazy';
     "
     tal:condition="elements"
>
  <div class="carousel-indicators">
    <tal:indicators repeat="element elements">
      <button class="active"
              aria-current="true"
              aria-label="Slide ${repeat/element/index}"
              type="button"
              data-bs-slide-to="${repeat/element/index}"
              data-bs-target="#DynamicPageSlider-${context/id}"
              i18n:attributes="aria-label"
      ></button>
    </tal:indicators>
  </div>
  <div class="carousel-inner"
       tal:define="
         macros context/@@macros/macros;
         can_edit context/can_edit;
       "
  >
    <tal:slides repeat="brain elements">
      <div tal:define="
             element brain/getObject;
           "
           tal:attributes="
             class python: repeat['brain'].index == 0 and 'carousel-item active bg-dark' or 'carousel-item bg-dark';
           "
      >
        <div class="ratio ratio-21x9 w-100">
          <div class="w-100 h-100">
            <div class="p-2 nested-management-options d-flex gap-2 position-absolute top-0 start-0 z-3"
                 tal:condition="can_edit"
            >
              <metal:use_macro use-macro="macros/management_icons" />
            </div>
            <replace tal:replace="structure python:element.render(request)"></replace>
          </div>
        </div>
        <tal:define define="
                      position python:repeat['brain'].index + 1;
                      container_uid context/UID;
                      is_nested string:True;
                    ">
          <metal:use_macro use-macro="macros/add_button" />
        </tal:define>
      </div>
    </tal:slides>
  </div>
  <button class="carousel-control-prev"
          type="button"
          data-bs-slide="prev"
          data-bs-target="#DynamicPageSlider-${context/id}"
  >
    <span class="carousel-control-prev-icon"
          aria-hidden="true"
    ></span>
    <span class="visually-hidden"
          i18n:translate=""
    >Previous</span>
  </button>
  <button class="carousel-control-next"
          type="button"
          data-bs-slide="next"
          data-bs-target="#DynamicPageSlider-${context/id}"
  >
    <span class="carousel-control-next-icon"
          aria-hidden="true"
    ></span>
    <span class="visually-hidden"
          i18n:translate=""
    >Next</span>
  </button>
</div>
