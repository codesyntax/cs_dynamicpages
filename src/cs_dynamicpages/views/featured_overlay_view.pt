<div class="card border-0 shadow-sm rounded overflow-hidden">

  <tal:image tal:define="
               image view/related_image;
             " tal:condition="image">
    <div class="ratio ratio-21x9 bg-dark">
      <img class="object-fit-cover w-100 h-100 opacity-50" tal:define="
             images image/@@images;
             fetchpriority_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'high' or 'auto') or 'auto';
             loading_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'eager' or 'lazy') or 'lazy';
           " tal:replace="structure python:images.srcset(fieldname='image',
                                        scale_in_src='huge',
                                        sizes='(min-width: 1400px) 1400px, 100vw',
                                        alt=image.Title() ,
                                        title=image.Title(),
                                        fetchpriority=fetchpriority_image_value,
                                        loading=loading_image_value,
                                        css_class='object-fit-cover w-100 h-100 opacity-50')" />
    </div>
  </tal:image>
  <!-- Overlay-a flex-column egingo dugu behera (end) bidaltzeko edukia -->
  <div class="card-img-overlay d-flex flex-column justify-content-end p-0">
    <div class="p-4 p-md-5 mt-auto w-100 bg-dark bg-opacity-50">
      <h3 class="text-white">${context/Title}</h3>
      <p class="lead d-none d-md-block text-white" tal:condition="context/Description">${context/Description}</p>
      <a class="btn btn-primary shadow-sm" href="${context/url}" tal:condition="context/url">${context/link_text}</a>
    </div>
  </div>
</div>