<div class="row g-4 align-items-center">
  <div class="col-md-6">
    <tal:image tal:define="
                 image view/related_image;
               " tal:condition="image">
      <div class="ratio ratio-4x3 bg-light rounded overflow-hidden shadow-sm">
        <img tal:define="
               images image/@@images;
               fetchpriority_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'high' or 'auto') or 'auto';
               loading_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'eager' or 'lazy') or 'lazy';
             " tal:replace="structure python:images.srcset(fieldname='image',
                                            scale_in_src='huge',
                                            sizes='(min-width: 1400px) 1400px, 100vw',
                                            alt=image.Title() ,
                                            title=image.Title(),
                                            fetchpriority=fetchpriority_image_value,
                                            loading=loading_image_value,
                                            css_class='object-fit-cover w-100 h-100')" />
      </div>
    </tal:image>
  </div>
  <div class="col-md-6 d-flex flex-column justify-content-center" tal:attributes="
         class python:context.image_position=='right' and 'col-md-6 order-first d-flex flex-column justify-content-center' or 'col-md-6 d-flex flex-column justify-content-center';
       ">
    <h3>${context/Title}</h3>
    <p class="lead" tal:condition="context/Description">${context/Description}</p>
    <div>
      <tal:replace tal:condition="context/text" replace="structure context/text/output">
      </tal:replace>
    </div>
    <div>
      <a class="btn btn-primary px-4 shadow-sm" href="${context/url}"
        tal:condition="context/url">${context/link_text}</a>
    </div>
  </div>
</div>