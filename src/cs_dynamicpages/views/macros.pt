<tal:block xmlns="http://www.w3.org/1999/xhtml"
           xmlns:i18n="http://xml.zope.org/namespaces/i18n"
           xmlns:metal="http://xml.zope.org/namespaces/metal"
           xmlns:tal="http://xml.zope.org/namespaces/tal"
>

  <!-- Unified Add Row Button -->
  <metal:add_button define-macro="add_button">
    <div tal:define="
           is_nested is_nested|nothing;
           container_uid container_uid|nothing;
           pos position|nothing;
           can_edit can_edit|nothing;
         "
         tal:condition="can_edit"
         tal:attributes="
           class python:'add-row-plus-container edit-options d-flex justify-content-center my-3' + (is_nested and ' nested' or '');
         "
    >
      <button class="btn btn-sm btn-outline-primary rounded-circle add-row-plus-btn"
              title="Add row here"
              data-bs-target="#addrow-offcanvasRight"
              data-bs-toggle="offcanvas"
              tal:attributes="
                data-position pos;
                data-container container_uid;
              "
              i18n:attributes="title"
      >
        <svg xmlns="http://www.w3.org/2000/svg"
             class="bi bi-plus-lg"
             fill="currentColor"
             height="16"
             viewbox="0 0 16 16"
             width="16"
        >
          <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"
                fill-rule="evenodd"
          ></path>
        </svg>
      </button>
    </div>
  </metal:add_button>

  <!-- Unified Row Management Icons (Pen/Trash) -->
  <metal:management_icons define-macro="management_icons">
    <div class="nested-management-options d-flex gap-2"
         tal:define="
           can_edit can_edit|nothing;
         "
         tal:condition="can_edit"
    >
      <a class="btn btn-outline-primary btn-sm rounded-circle"
         href="${element/absolute_url}/edit"
         title="Edit"
         i18n:attributes="title"
      >
        <svg xmlns="http://www.w3.org/2000/svg"
             class="bi bi-pencil-fill"
             fill="currentColor"
             height="14"
             viewbox="0 0 16 16"
             width="14"
        >
          <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"></path>
        </svg>
      </a>
      <a class="btn btn-outline-danger btn-sm rounded-circle"
         href="${element/absolute_url}/delete_confirmation"
         title="Delete"
         i18n:attributes="title"
      >
        <svg xmlns="http://www.w3.org/2000/svg"
             class="bi bi-trash3"
             fill="currentColor"
             height="14"
             viewbox="0 0 16 16"
             width="14"
        >
          <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"></path>
        </svg>
      </a>
    </div>
  </metal:management_icons>

</tal:block>
