<div class="card h-100 border-0 shadow-sm rounded overflow-hidden">
  <tal:image tal:define="
               image context/related_image_object;
               fetchpriority_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'high' or 'auto') or 'auto';
               loading_image_value python:hasattr(context, 'fetchpriority_image') and (context.fetchpriority_image and 'eager' or 'lazy') or 'lazy';
             "
             tal:condition="image"
  >
    <div class="ratio ratio-16x9 bg-light">
      <img tal:define="
             images image/@@images;
           "
           tal:replace="structure python:images.srcset(fieldname='image',
                                                              scale_in_src='huge',
                                                              sizes='(min-width: 1400px) 400px, 100vw',
                                                              alt=context.Title() ,
                                                              title=context.Title(),
                                                              fetchpriority=fetchpriority_image_value,
                                                              loading=loading_image_value,
                                                              css_class='object-fit-cover w-100 h-100')"
      />
    </div>
  </tal:image>
  <div class="card-body p-4 d-flex flex-column">
    <h3 class="h5 card-title mb-3"
        tal:condition="context/url"
    >
      <a class="text-dark no-underline stretched-link fw-bold"
         href="${context/url}"
      >${context/Title}</a>
    </h3>
    <h3 class="h5 card-title fw-bold text-dark mb-3"
        tal:condition="not:context/url"
    >${context/Title}</h3>
    <p class="card-text text-secondary mb-4"
       tal:condition="context/Description"
    >${context/Description}</p>
    <div class="mt-auto text-muted">
      <tal:replace tal:condition="context/text"
                   replace="structure context/text/output"
      >
      </tal:replace>
    </div>
  </div>
</div>
