<?xml version="1.0" encoding="utf-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      metal:use-macro="context/main_template/macros/master"
      data-portal-url="${portal_url}"
      tal:define="
        portal_url context/portal_url;
      "
      i18n:domain="cs_dynamicpages"
>

  <body>
    <metal:main fill-slot="main">
      <main id="dynamic_pages_content"
            tal:define="
              macros context/@@macros/macros;
              icons_view nocall:context/@@iconresolver;
            "
      >

        <tal:condition-configuration condition="view/dynamic_page_folder_element">
          <tal:conditiondrapanddrop tal:condition="view/can_edit">
            <script id="sortable-js"
                    src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"
            ></script>
          </tal:conditiondrapanddrop>
          <tal:features define="
                          rows view/rows;
                          can_edit view/can_edit;
                        ">
            <tal:define define="
                          position string:0;
                        ">
              <metal:use_macro use-macro="macros/add_button" />
            </tal:define>

            <tal:featured repeat="brain rows">
              <div class="dynamic-row-wrapper"
                   data-delete-target="true"
                   data-move-target="true"
                   tal:define="
                     row brain/getObject;
                   "
                   tal:attributes="
                     data-elementid row/id;
                     data-elementurl row/absolute_url;
                     data-parenturl row/aq_parent/absolute_url;
                   "
              >

                <section class="dynamic-row dynamic-row-number-${repeat/brain/number} dynamic-row-${python:repeat['brain'].number() % 2 == 0 and 'even' or 'odd'} ${row/row_template} state-${row/review_state} ${row/extra_class|nothing} ${row/padding_top|nothing} ${row/padding_bottom|nothing} ${row/margin_top|nothing} ${row/margin_bottom|nothing}"
                         id="${row/id}"
                >
                  <div class="gap-2 edit-options edit-buttons d-flex"
                       tal:condition="row/can_edit"
                  >
                    <div class="drag-handle"
                         title="Drag and drop"
                         i18n:attributes="title"
                    >
                      <span tal:replace="structure python:icons_view.tag('arrows-move')"></span>
                    </div>
                    <small class="px-2 py-1 mb-3 border d-inline-flex align-items-center fw-semibold text-warning-emphasis bg-warning-subtle border-warning-subtle rounded-2 position-relative">
                      <span tal:replace="structure python:icons_view.tag('info-circle')"></span>
                      <span i18n:translate="">Template:
                        <span i18n:name="template_id">${row/row_template}</span></span>
                    </small>

                    <a class="btn btn-outline-primary btn-sm align-self-start"
                       href="${row/absolute_url}/edit"
                       title="Edit"
                       i18n:attributes="title"
                    ><span tal:replace="structure python:icons_view.tag('pencil')"></span></a>
                    <a class="btn btn-sm btn-danger align-self-start btn-delete-element"
                       href="#"
                       title="Delete"
                       data-bs-target="#deleteElementModal"
                       data-bs-toggle="modal"
                       data-rowid="${row/id}"
                       i18n:attributes="title"
                    ><span tal:replace="structure python:icons_view.tag('trash')"></span></a>

                    <div class="gap-2 ms-auto d-flex align-items-start">

                      <a class="btn btn-outline-primary btn-sm align-self-start"
                         href="#"
                         title="Move up"
                         data-action="move-up"
                         tal:define="
                           is_first python:repeat['brain'].start;
                         "
                         tal:attributes="
                           style python:is_first and 'display:none' or '';
                         "
                         i18n:attributes="title"
                      ><span tal:replace="structure python:icons_view.tag('arrow-up')"></span></a>
                      <a class="btn btn-outline-primary btn-sm align-self-start"
                         href="#"
                         title="Move down"
                         data-action="move-down"
                         tal:define="
                           is_last python:repeat['brain'].end;
                         "
                         tal:attributes="
                           style python:is_last and 'display:none' or '';
                         "
                         i18n:attributes="title"
                      ><span tal:replace="structure python:icons_view.tag('arrow-down')"></span></a>
                      <div class="btn-group">
                        <a class="btn btn-secondary dropdown-toggle"
                           aria-expanded="false"
                           type="button"
                           data-bs-display="static"
                           data-bs-toggle="dropdown"
                           tal:attributes="
                             class python:row.review_state() == 'published' and                         'position-relative btn btn-outline-success btn-sm bg-success-subtle dropdown-toggle' or                         'position-relative btn btn-outline-danger btn-sm bg-danger-subtle dropdown-toggle';
                           "
                        >
                          <span tal:replace="structure python:icons_view.tag('info-circle')"></span>
                          <span tal:omit-tag=""
                                i18n:translate=""
                          >Review state:
                            <span tal:omit-tag=""
                                  i18n:domain="plone"
                                  i18n:name="state"
                                  i18n:translate=""
                            >${row/review_state}</span></span>
                          <span tal:attributes="
                                  class python:row.review_state() == 'published' and 'position-absolute top-0 start-100 translate-middle p-2 bg-success border border-light rounded-circle' or 'position-absolute top-0 start-100 translate-middle p-2 bg-danger border border-light rounded-circle';
                                ">
                          </span>
                        </a>
                        <ul class="dropdown-menu"
                            tal:define="
                              transitions python:context.portal_workflow.getTransitionsFor(row);
                            "
                        >
                          <tal:transitions repeat="transition transitions">
                            <li><a class="dropdown-item"
                                 href="${transition/url}&amp;_authenticator=${context/@@authenticator/token}"
                                 i18n:domain="plone"
                                 i18n:translate=""
                              >${transition/name}</a>
                            </li>
                          </tal:transitions>
                        </ul>
                      </div>
                    </div>

                  </div>
                  <tal:condition tal:condition="row/can_edit">
                    <div class="flex-wrap gap-2 mb-3 nested-add-options child-list d-flex align-items-start">
                      <tal:featured_add_button tal:condition="row/show_add_child_button">
                        <a class="btn btn-outline-primary btn-sm align-self-start"
                           href="${row/absolute_url}/++add++DynamicPageRow"
                           title="Add nested row"
                           i18n:attributes="title"
                        ><span tal:replace="structure python:icons_view.tag('plus')"></span>
                          <span i18n:translate="">Row</span></a>
                      </tal:featured_add_button>
                    </div>
                  </tal:condition>
                  <div class="content row g-0">
                    <div class="${row/width}">
                      <tal:block replace="structure python:row.render(request)" />
                    </div>
                  </div>
                </section>
                <tal:define define="
                              position python:repeat['brain'].index + 1;
                            ">
                  <metal:use_macro use-macro="macros/add_button" />
                </tal:define>
              </div>
            </tal:featured>
          </tal:features>
          <tal:condition tal:condition="view/can_edit">
            <div class="sticky-bottom rows-mangement d-flex justify-content-center align-items-center gap-5"
                 tal:condition="view/dynamic_page_folder_element_url"
            >
              <div tal:condition="python:len(view.rows()) and not view.self_in_templates()">
                <!-- Button trigger modal -->
                <button class="btn btn-primary"
                        type="button"
                        data-bs-target="#templateModal"
                        data-bs-toggle="modal"
                        i18n:translate=""
                >
                Save as template
                </button>
                <!-- Modal -->
              </div>
              <!-- <a class="btn btn-primary"
                 aria-controls="offcanvasRight"
                 title="Add row"
                 data-bs-target="#addrow-offcanvasRight"
                 data-bs-toggle="offcanvas"
                 tal:attributes="
                   data-position python:len(view.rows());
                 "
                 i18n:attributes="title"
              ><svg xmlns="http://www.w3.org/2000/svg"
                     class="bi bi-plus-lg"
                     fill="currentColor"
                     height="16"
                     viewbox="0 0 16 16"
                     width="16"
                >
                  <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"
                        fill-rule="evenodd"
                  ></path>
                </svg>
              </a> -->
              <div class="px-3 py-2 border d-inline-flex align-items-center fw-semibold text-warning-emphasis bg-warning-subtle border-warning-subtle rounded-5">
                <div class="form-check form-switch">
                  <input class="form-check-input"
                         id="editModeToggle"
                  />role="switch"
                         type="checkbox"
                  /&gt;
                  <label class="form-check-label"
                         for="editModeToggle"
                         i18n:translate=""
                  >Edit Mode</label>
                </div>
              </div>
            </div>
            <div class="offcanvas offcanvas-end"
                 id="addrow-offcanvasRight"
                 aria-labelledby="offcanvasRightLabel"
                 tabindex="-1"
                 tal:define="
                   available_views_for_row view/available_views_for_row;
                   templates python:view.available_templates();
                   empty_rows python:len(view.rows()) == 0;
                 "
            >
              <div class="offcanvas-header">
                <h2 class="offcanvas-title h5"
                    id="offcanvasRightLabel"
                    i18n:translate=""
                >Add new row</h2>
                <button class="btn-close"
                        aria-label="Close"
                        type="button"
                        data-bs-dismiss="offcanvas"
                        i18n:attributes="aria-label"
                ></button>
              </div>
              <div class="offcanvas-body">
                <div class="templates-listing"
                     tal:condition="python: empty_rows and templates"
                >
                  <h2 class="mb-3 h6"
                      i18n:translate=""
                  >Reuse existing templates</h2>
                  <div class="accordion"
                       id="templateAccordion"
                  >
                    <div class="accordion-item"
                         tal:repeat="template templates"
                    >
                      <span class="accordion-header">
                        <button class="accordion-button collapsed"
                                aria-controls="collapse-${repeat/template/number}"
                                aria-expanded="false"
                                type="button"
                                data-bs-target="#collapse-${repeat/template/number}"
                                data-bs-toggle="collapse"
                        >
                        ${template/name}
                        </button>
                      </span>
                      <div class="accordion-collapse collapsed collapse"
                           id="collapse-${repeat/template/number}"
                           data-bs-parent="#templateAccordion"
                      >
                        <div class="accordion-body">
                          <a class="btn btn-outline-primary btn-sm preview-template-btn"
                             href="${template/absolute_url}"
                             data-template-name="${template/name}"
                             i18n:translate=""
                          >See
                          this
                          template
                          </a>

                          <a class="btn btn-outline-success btn-sm apply-template"
                             href="#"
                             data-uid="${template/uid}"
                             i18n:translate=""
                          >Apply this template
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>

                </div>
                <tal:conditionrows tal:condition="python: empty_rows and templates">
                  <div class="my-5"
                       tal:condition="templates"
                  ></div>
                  <h2 class="mb-3 h6"
                      i18n:translate=""
                  >Add block</h2>
                </tal:conditionrows>
                <ul class="list-unstyled row">
                  <li class="mb-2 col-4"
                      tal:repeat="item available_views_for_row"
                  >
                    <div class="p-5 rounded bg-light h-100 available-view">
                      <a class="no-underline d-flex flex-column align-items-center justify-content-between h-100"
                         href="${view/dynamic_page_folder_element_url}/add-row-content?row_type=${item/row_type}"
                      >
                        <span class="mb-2"
                              tal:replace="structure python:icons_view.tag(item['row_type_icon'], tag_class='fs-1')"
                        ></span>
                        <span class="text-center small"
                              tal:content="python:view.normalize_title(item['row_type'])"
                        ></span>
                      </a>
                    </div>
                  </li>
                </ul>
              </div>
            </div>
          </tal:condition>
          <!-- Delete Confirmation Modal -->
          <div class="modal fade"
               id="deleteElementModal"
               aria-hidden="true"
               aria-labelledby="deleteElementModalLabel"
               tabindex="-1"
          >
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h2 class="modal-title h5"
                      id="deleteElementModalLabel"
                      i18n:translate=""
                  >Confirm Deletion</h2>
                  <button class="btn-close"
                          aria-label="Close"
                          type="button"
                          data-bs-dismiss="modal"
                          i18n:attributes="aria-label"
                  ></button>
                </div>
                <div class="modal-body">
                  <p i18n:translate="">Are you sure you want to delete this item? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                  <button class="btn btn-secondary"
                          type="button"
                          data-bs-dismiss="modal"
                          i18n:translate=""
                  >Cancel</button>
                  <button class="btn btn-danger"
                          id="confirmDeleteElement"
                          type="button"
                          i18n:translate=""
                  >Delete</button>
                </div>
              </div>
            </div>
          </div>
          <script>
          // Selecciona todos los elementos con el atributo data-bs-toggle="tooltip"
          const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');

          // Crea una instancia de tooltip para cada elemento encontrado
          const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl =&gt; new bootstrap.Tooltip(tooltipTriggerEl));
          </script>
          <div class="bottom-0 p-3 toast-container position-fixed end-0">
            <div class="toast"
                 id="liveToast"
                 aria-atomic="true"
                 aria-live="assertive"
                 role="alert"
            >
              <div class="toast-header">
                <strong class="me-auto"
                        i18n:translate=""
                >Notification</strong>
                <button class="btn-close"
                        aria-label="Close"
                        type="button"
                        data-bs-dismiss="toast"
                        i18n:attributes="aria-label"
                ></button>
              </div>
              <div class="toast-body">
              </div>
            </div>
          </div>
        </tal:condition-configuration>

        <div class="modal fade"
             id="templateModal"
             aria-hidden="true"
             aria-labelledby="addTemplateModal"
             tabindex="-1"
        >
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h2 class="modal-title fs-5"
                    id="addTemplateModal"
                    i18n:translate=""
                >Add template</h2>
                <button class="btn-close"
                        aria-label="Close"
                        type="button"
                        data-bs-dismiss="modal"
                        i18n:attributes="aria-label"
                ></button>
              </div>
              <div class="modal-body">
                <form>
                  <div class="mb-3">
                    <label class="col-form-label"
                           for="template-name"
                           i18n:translate=""
                    >Template name:</label>
                    <input class="form-control"
                           id="template-name"
                           required="required"
                           type="text"
                    />
                  </div>
                </form>
              </div>
              <div class="modal-footer">
                <button class="btn btn-secondary"
                        type="button"
                        data-bs-dismiss="modal"
                        i18n:translate=""
                >Close</button>
                <button class="btn btn-primary"
                        id="addAsTemplate"
                        type="button"
                        data-uid="${python:view.dynamic_page_folder_element().UID()}"
                        i18n:translate=""
                >Save as
                  template</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Template Preview Modal -->
        <div class="modal fade"
             id="previewTemplateModal"
             aria-hidden="true"
             aria-labelledby="previewTemplateModalLabel"
             tabindex="-1"
        >
          <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg">
              <div class="modal-header bg-white border-bottom">
                <h2 class="modal-title h5 text-primary fw-semibold"
                    id="previewTemplateModalLabel"
                    i18n:translate=""
                >
                  Template Preview</h2>
                <button class="btn-close"
                        aria-label="Close"
                        type="button"
                        data-bs-dismiss="modal"
                        i18n:attributes="aria-label"
                ></button>
              </div>
              <div class="modal-body p-4 bg-light">
                <!-- Marko txukuna (kuadro efektua) -->
                <div class="bg-white border rounded shadow p-4 mx-auto"
                     id="previewTemplateBody"
                     style="min-height: 200px; zoom: 0.50;"
                >
                  <!-- Content will be injected here via JS -->
                </div>
              </div>
              <div class="modal-footer bg-white border-top">
                <button class="btn btn-light"
                        type="button"
                        data-bs-dismiss="modal"
                        i18n:translate=""
                >Close</button>
              </div>
            </div>
          </div>
        </div>

      </main>
    </metal:main>

  </body>

</html>
